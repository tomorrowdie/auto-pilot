# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_seo
REDIS_URL=redis://localhost:6379

# Application Settings
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Shopify Configuration
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,read_orders,read_customers,read_content,read_themes
SHOPIFY_APP_URL=https://your-app-domain.com

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Google APIs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_API_KEY=your_google_api_key

# Bing Webmaster Tools
BING_WEBMASTER_API_KEY=your_bing_api_key

# Amazon Keyword Database (if using external service)
AMAZON_KEYWORD_API_KEY=your_amazon_keyword_api_key
AMAZON_KEYWORD_API_URL=https://api.example.com

# Email Configuration (for reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@yourdomain.com

# Monitoring and Logging
SENTRY_DSN=your_sentry_dsn_for_error_tracking
LOG_LEVEL=INFO

# Rate Limiting
API_RATE_LIMIT=100
OPENAI_RATE_LIMIT=50

# File Storage (for reports and exports)
STORAGE_TYPE=local  # local, s3, gcs
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=your_s3_bucket
AWS_REGION=us-east-1

# Development Settings
DEBUG=true
RELOAD=true
WORKERS=1